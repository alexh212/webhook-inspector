# Database (required) — must use asyncpg driver
DATABASE_URL=postgresql+asyncpg://localhost/webhookinspector

# Redis (required for real-time feed and retry queue)
REDIS_URL=redis://localhost:6379

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Set to true to enable SQL query logging (do NOT use in production)
DEBUG=false
